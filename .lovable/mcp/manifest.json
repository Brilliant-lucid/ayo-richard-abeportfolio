        "description": "Fetch the signed-in user's portfolio settings (username, published status, hero, site info).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "list_projects",
        "title": "List my projects",
        "description": "List all portfolio projects owned by the signed-in user, including drafts.",
